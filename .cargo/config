[target.x86_64-pc-windows-msvc]
rustflags = ["-C", "target-feature=+crt-static"]

[target.x86_64-unknown-linux-gnu]
linker = "clang"
rustflags = ["-C", "link-arg=-fuse-ld=mold"]

# Android NDK targets - use `cargo ndk` instead of manual linker config.
# Install: cargo install cargo-ndk
# Build:   cargo ndk -t arm64-v8a -o android/app/src/main/jniLibs build --bin uad_android --no-default-features
#
# Manual linker config (requires NDK r25+ installed at $ANDROID_NDK_HOME):
# [target.aarch64-linux-android]
# linker = "$ANDROID_NDK_HOME/toolchains/llvm/prebuilt/<host>/bin/aarch64-linux-android26-clang"
